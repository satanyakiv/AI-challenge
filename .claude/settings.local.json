{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prompt-router.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(java:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "WebSearch",
      "WebFetch(domain:api-docs.deepseek.com)",
      "Bash(sleep 1:*)",
      "Skill(statusline)",
      "Bash(head:*)",
      "Bash(curl:*)",

      "Bash(gh repo:*)",
      "Bash(python3:*)",
      "Bash(echo Port 8080 cleared:*)",
      "Bash(claude update:)",
      "Bash(claude:*)",
      "WebFetch(domain:docs.koog.ai)",
      "WebFetch(domain:mvnrepository.com)",
      "WebFetch(domain:api.koog.ai)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:central.sonatype.com)"
    ]
  },
  "enabledPlugins": {
    "kotlin-agents@kotlin-agents-marketplace": true
  },
  "outputStyle": "Explanatory"
}
